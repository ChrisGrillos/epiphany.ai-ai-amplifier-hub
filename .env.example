# Epiphany.AI — Environment Configuration
# Copy this file to .env.local and fill in your values.
#
# Get these from your Base44 dashboard:
# 1. Log in to https://app.base44.com
# 2. Open your Epiphany AI app
# 3. Go to Settings → General
# 4. Copy the App ID and Base URL

VITE_BASE44_APP_ID=your_app_id_here
VITE_BASE44_APP_BASE_URL=https://your-app-name.base44.app
